@page "/"
@inject IVoteService VoteService
@inject IResultService ResultService

<PageTitle>Drama Meter</PageTitle>

<div class="page">
    @if (_isLoading)
    {
        <div class="loading">Loading drama meter…</div>
    }
    else
    {
        <h1 class="title">MUDDI's Drama Meter</h1>

        <!-- Gauge with animated needle, last-vote dots, and click-to-vote -->
        <Gauge DramaLevel="@_dramaLevel"
               ShowNeedle="true"
               LastVotePositions="@_lastVotePositions"
               OnVoteRequested="HandleGaugeVote" />

        <!-- Cooldown countdown -->
        @if (_cooldownRemaining.HasValue)
        {
            <CooldownTimer Remaining="@_cooldownRemaining.Value"
                           OnElapsed="OnCooldownElapsed" />
        }

        <!-- Delete vote -->
        @if (_hasVoted)
        {
            <button class="delete-btn" @onclick="DeleteVote">Delete Vote</button>
        }

        <!-- Total votes cast -->
        @if (_dramaResult?.TotalVoteCount > 0)
        {
            <span class="vote-count">
                @_dramaResult.TotalVoteCount vote@(_dramaResult.TotalVoteCount == 1 ? "" : "s") cast
            </span>
        }
    }
</div>

@code {
    private DramaResult? _dramaResult;
    private bool _isLoading = true;
    private bool _hasVoted;
    private TimeSpan? _cooldownRemaining;
    private double _dramaLevel;
    private List<(double X, double Y)> _lastVotePositions = new();

    private bool _isCooldown => _cooldownRemaining.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _dramaResult = await ResultService.GetDramaResultAsync();
        _dramaLevel = _dramaResult.DramaLevel;
        _lastVotePositions = _dramaResult.ClickPositions ?? new();

        var lastVote = await VoteService.GetUserLastVoteAsync();
        _hasVoted = lastVote != null;
        _cooldownRemaining = VoteService.GetCooldownRemaining(lastVote?.CreatedAt);
        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleGaugeVote((int level, double angle, double viewBoxX, double viewBoxY) args)
    {
        try
        {
            await VoteService.SubmitVoteAsync(args.level, args.angle, args.viewBoxX, args.viewBoxY);
        }
        catch (InvalidOperationException)
        {
            // Already in cooldown — just refresh state
        }

        await LoadAsync();
    }

    private async Task DeleteVote()
    {
        await VoteService.DeleteMostRecentVoteAsync();
        await LoadAsync();
    }

    private async Task OnCooldownElapsed()
    {
        await LoadAsync();
    }
}
