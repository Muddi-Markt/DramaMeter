@page "/"
@inject IVoteService VoteService
@inject IResultService ResultService
@inject ILogger<Index> Logger
@inject IJSRuntime JsRuntime
@inject IOptions<DramaMeterSettings> Settings

<PageTitle>@Settings.Value.Title @Settings.Value.Subtitle</PageTitle>

<div class="page">

    <!-- Gauge with animated needle, last-vote dots, and click-to-vote -->
    <div class="gauge-container">
        <Gauge DramaLevel="@_dramaLevel"
               ShowResults="@_hasVoted"
               LastVotePositions="@_lastVotePositions"
               OnVoteRequested="HandleGaugeVote"/>
        <div class="gauge-overlay-text">
            <h1>@Settings.Value.Title</h1>
            <h2>@Settings.Value.Subtitle</h2>
        </div>
    </div>

    <footer>
        @if (!_hasVoted)
        {
            <div>
                <h4>Na, wie ist die Stimmung gerade?</h4>
                <p>Klicke auf den Bereich, der am besten zu deiner MUDDI Stimmung passt</p>
            </div>
        }
        <!-- Cooldown countdown -->
        @if (_lastVote is not null && _hasVoted)
        {
            <CooldownTimer CooldownAt="@_lastVote.CreatedAt"
                           OnElapsed="OnCooldownElapsed"/>
        }

        <!-- Delete vote -->
        @if (_hasVoted)
        {
            <button class="delete-btn" @onclick="DeleteVote">Lösche dein Vote</button>
        }

        <!-- Total votes cast -->
        @if (_dramaResult?.TotalVoteCount > 0)
        {
            <span class="vote-count">
                @_dramaResult.TotalVoteCount vote@(_dramaResult.TotalVoteCount == 1 ? "" : "s")
            </span>
        }
    </footer>
</div>

@code {
    private DramaResult? _dramaResult;
    private Vote? _lastVote;
    private bool _hasVoted;
    private double _dramaLevel;
    private List<UserPoint> _lastVotePositions = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _dramaResult = await ResultService.GetDramaResultAsync();
        _dramaLevel = _dramaResult.DramaLevel;
        _lastVotePositions = _dramaResult.ClickPositions;

        _lastVote = await VoteService.GetUserLastVoteAsync();

        var cooldownRemaining = VoteService.GetCooldownRemaining(_lastVote?.CreatedAt);
        _hasVoted = cooldownRemaining.HasValue;
#if DEBUG
        if (_dramaResult.TotalVoteCount == 0)
            await ((ResultService)ResultService).CreateDummies();
#endif
    }

    private async Task HandleGaugeVote(UserPoint userPoint)
    {
        try
        {
            await VoteService.SubmitVoteAsync(userPoint);
        }
        catch (Exception ex) when (ex is ArgumentException or InvalidOperationException)
        {
            Logger.LogInformation("Click was not updated: {ErrorMessage}", ex.Message);
            await JsRuntime.InvokeVoidAsync("console.log", "Failed to update click: " + ex.Message);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update click");
            await JsRuntime.InvokeVoidAsync("console.error", "Failed to update click: " + ex.Message);
        }

        await LoadAsync();
    }

    private async Task DeleteVote()
    {
        await VoteService.DeleteMostRecentVoteAsync();
        await LoadAsync();
    }

    private async Task OnCooldownElapsed()
    {
        await LoadAsync();
    }

}
