@using Muddi.DramaMeter.Blazor.Services
@using Muddi.DramaMeter.Blazor.Models
@inject IJSRuntime JS

<svg @ref="_svgRef" viewBox="0 0 440 320" class="gauge-svg" aria-label="Drama gauge"
     @onclick="OnGaugeClick">

    @* Needle pivot shadow *@
    <circle cx="@Cx" cy="@Cy" r="@InnerR + 5" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1"/>

    @* 4 colored arc segments *@
    @for (int i = 0; i < 4; i++)
    {
        var startAngle = 180 - i * 45.0;
        var endAngle = 180 - (i + 1) * 45.0;
        <path d="@GetArcPath(startAngle, endAngle)" fill="@Colors[i]" class="gauge-segment"/>
    }

    @* Animated needle *@
    @if (ShowNeedle)
    {
        <g class="needle" style="transform: rotate(@(NeedleAngle)deg)">
            <line x1="@Cx" y1="@Cy" x2="@Cx" y2="@NeedleTipY"
                  stroke="white" stroke-width="3" stroke-linecap="round"/>
            <circle cx="@Cx" cy="@Cy" r="7" fill="white" stroke="rgba(0,0,0,0.2)" stroke-width="1"/>
        </g>
    }

    @* Segment labels — raw HTML since <text> is Razor-reserved *@
    @for (int i = 0; i < 4; i++)
    {
        var midAngle = 180 - (i + 0.5) * 45.0;
        var lx = Cx + LabelR * Math.Cos(midAngle * Math.PI / 180);
        var ly = Cy - LabelR * Math.Sin(midAngle * Math.PI / 180);
        <text>
            <text x="@lx" y="@ly" text-anchor="middle" dominant-baseline="middle"
                  class="gauge-label">@Labels[i]</text></text>
    }

    @* Last 10 vote dots — rendered directly inside this SVG *@
    @if (LastVotePositions is not null && LastVotePositions.Any())
    {
        <LastVotes Positions="@LastVotePositions"/>
    }
</svg>

@code {
    private ElementReference _svgRef;
    private double _scaleX = 1;
    private double _scaleY = 1;
    private double _rectLeft = 0;
    private double _rectTop = 0;

    private const double Cx = 220;
    private const double Cy = 180;
    private const double OuterR = 130;
    private const double InnerR = 96;
    private const double LabelR = 168;
    private const double NeedleLen = 115;

    private static readonly string[] _colors = { "#4caf50", "#fdd835", "#ff9800", "#c62828" };
    private static readonly string[] _labels = { "No Drama", "Es knistert", "Bodenlos!", "SONDERPLENUM" };

    private string[] Colors => _colors;
    private string[] Labels => _labels;

    [Parameter] public DramaResult? Result { get; set; }
    [Parameter] public bool ShowNeedle { get; set; }
    [Parameter] public double DramaLevel { get; set; } = 0;
    [Parameter] public List<(double X, double Y)>? LastVotePositions { get; set; }

    /// <summary>
    /// Fired when the user clicks on the gauge.
    /// </summary>
    [Parameter]
    public EventCallback<(int level, double angle, double viewBoxX, double viewBoxY)> OnVoteRequested { get; set; }

    private double NeedleAngle => DramaLevel * 60.0 - 90.0;
    private double NeedleTipY => Cy - NeedleLen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await GetCurrentScaleAsync();
        }
    }

    private async Task GetCurrentScaleAsync()
    {
        // Get SVG display dimensions and element position once
        var size = await JS.InvokeAsync<double[]>(
            "dramaMeterHelpers.getSvgScale", _svgRef);
        var rect = await JS.InvokeAsync<double[]>(
            "dramaMeterHelpers.getBoundingClientRect", _svgRef);

        var w = size[0];
        var h = size[1];
        _rectLeft = rect[0];
        _rectTop = rect[1];

        if (w > 0 && h > 0)
        {
            _scaleX = 440.0 / w;
            _scaleY = 320.0 / h;
        }
    }

    private async Task OnGaugeClick(MouseEventArgs e)
    {
        await GetCurrentScaleAsync();
        // Convert client coordinates to SVG viewBox coordinates.
        // Using clientX/clientY relative to the element is reliable
        // for both mouse and touch events on mobile.
        var cssX = e.ClientX - _rectLeft;
        var cssY = e.ClientY - _rectTop;
        if (cssY > 132)
            return;
        var svgX = cssX * _scaleX;
        var svgY = cssY * _scaleY;

        // Calculate angle from center: 180°=left, 90°=top, 0°=right
        var dx = svgX - Cx;
        var dy = svgY - Cy;
        var angle = Math.Atan2(-dy, dx) * 180.0 / Math.PI;

        // Clamp to the gauge arc range
        angle = Math.Clamp(angle, 0, 180);

        // Map angle to level: 180→0, 135→1, 90→2, 45→3, 0→3
        var level = Math.Min(3, (int)((180 - angle) / 45));

        _ = OnVoteRequested.InvokeAsync((level, angle, svgX, svgY));
    }

    private string GetArcPath(double startAngle, double endAngle)
    {
        var sCos = Math.Cos(startAngle * Math.PI / 180);
        var sSin = Math.Sin(startAngle * Math.PI / 180);
        var eCos = Math.Cos(endAngle * Math.PI / 180);
        var eSin = Math.Sin(endAngle * Math.PI / 180);

        var x1 = Cx + OuterR * sCos;
        var y1 = Cy - OuterR * sSin;
        var x2 = Cx + OuterR * eCos;
        var y2 = Cy - OuterR * eSin;
        var x3 = Cx + InnerR * eCos;
        var y3 = Cy - InnerR * eSin;
        var x4 = Cx + InnerR * sCos;
        var y4 = Cy - InnerR * sSin;

        return $"""M {x1:F1},{y1:F1} A {OuterR},{OuterR} 0 0 1 {x2:F1},{y2:F1} L {x3:F1},{y3:F1} A {InnerR},{InnerR} 0 0 0 {x4:F1},{y4:F1} Z""";
    }

}
