@implements IAsyncDisposable
@inject IVoteService VoteService

@if (_remaining > TimeSpan.Zero)
{
    <div class="cooldown-timer">
        <span class="cooldown-icon">⏱</span>
        <span class="cooldown-text">
            Du kannst in @FormatRemaining() wieder abstimmen
        </span>
    </div>
}

@code {
    [Parameter] public DateTimeOffset CooldownAt { get; set; }
    [Parameter] public EventCallback OnElapsed { get; set; }

    private DateTimeOffset _oldCooldownAt;

    private TimeSpan _remaining;
    private Timer? _timer;
    private bool _disposed;

    protected override void OnParametersSet()
    {
        if (_oldCooldownAt == CooldownAt)
            return;
        _oldCooldownAt = CooldownAt;
        var remaining = VoteService.GetCooldownRemaining(CooldownAt);
        
        if (!remaining.HasValue)
            return;
        _remaining = remaining.Value;
        StopTimer();
        StartTimer();
    }

    private void StartTimer()
    {
        if (_remaining > TimeSpan.Zero)
        {
            _timer = new Timer(OnTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        }
    }

    private void StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
    }

    private void OnTick(object? state)
    {
        if (_disposed) return;

        InvokeAsync(async () =>
        {
            _remaining = _remaining.Subtract(TimeSpan.FromSeconds(1));
            if (_remaining < TimeSpan.Zero) _remaining = TimeSpan.Zero;

            StateHasChanged();

            if (_remaining <= TimeSpan.Zero)
            {
                StopTimer();
                await OnElapsed.InvokeAsync();
            }
        });
    }

    private string FormatRemaining()
    {
        if (_remaining.TotalMinutes >= 1)
        {
            return $"{_remaining.Minutes} min {_remaining.Seconds:00} sek";
        }

        return $"{_remaining.TotalSeconds:F0} sek";
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        StopTimer();
        return ValueTask.CompletedTask;
    }

}
