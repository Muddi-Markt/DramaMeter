@foreach (var pos in Positions.Where(x => x.Weight >= 0.1))
{
    var fillColor =
        pos.UserId == CurrentUser.Id
            ? "#5a5aAa"
            : "#1a1a1a";
    <circle class="vote-dot" cx="@pos.X" cy="@pos.Y" fill="@fillColor" r="4" opacity="@pos.Weight"/>
}


@code {
    [EditorRequired] [Parameter] public required List<UserPoint> Positions { get; set; }
    [CascadingParameter] public required User CurrentUser { get; set; }
}