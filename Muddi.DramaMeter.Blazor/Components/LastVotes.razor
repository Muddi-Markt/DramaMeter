@inject ISessionService SessionService
@foreach (var pos in Positions)
{
    var fillColor =
        pos.UserId == _myUserId
            ? "#5a5aAa"
            : "#1a1a1a";
    <circle class="vote-dot" cx="@pos.X" cy="@pos.Y" fill="@fillColor" r="4"/>
}


@code {
    [EditorRequired] [Parameter] public required List<UserPoint> Positions { get; set; }

    Guid _myUserId;

    protected override async Task OnInitializedAsync()
    {
        _myUserId = (await SessionService.GetOrCreateUserAsync()).Id;
    }

}